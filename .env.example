PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Storage Configuration (Cloudflare R2 / S3)
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_BUCKET=my-images
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# Proxy Configuration
# Set to 'false' to disable fetching from /url/*
ALLOW_EXTERNAL_URL=true

# Security (HMAC Signing)
# If set, all requests must include a ?sig=<hmac_sha256> parameter
APP_SECRET=your_super_secret_key_here
